from fastapi import APIRouter, Depends, HTTPException, status
from sqlalchemy.orm import Session
from typing import List

from app.database import get_db
from app.models import DBVehicle, DBTrip
from app.schemas import VehicleCreate, VehicleResponse, TripResponse
from app.dependencies import get_current_user_role  # Import role checker

router = APIRouter(prefix="/vehicles", tags=["Vehicles"])

# 1. POST Route: Add vehicle (MANAGER ONLY)
@router.post("", response_model=VehicleResponse)
def add_vehicle(vehicle: VehicleCreate, db: Session = Depends(get_db), role: str = Depends(get_current_user_role)):
    if role != "manager":
        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail="Access denied: Managers only")
    
    db_vehicle = db.query(DBVehicle).filter(DBVehicle.license_plate == vehicle.license_plate).first()
    if db_vehicle:
        raise HTTPException(status_code=400, detail="License plate already registered")
    
    new_vehicle = DBVehicle(make=vehicle.make, model=vehicle.model, year=vehicle.year, license_plate=vehicle.license_plate)
    db.add(new_vehicle)
    db.commit()
    db.refresh(new_vehicle)
    return new_vehicle

# 2. GET Route: Fetch all vehicles (MANAGERS & DRIVERS CAN ACCESS)
from typing import Optional # Ensure Optional is imported at the top if it  isn't
@router.get("", response_model=List[VehicleResponse])
def get_vehicles(db: Session = Depends(get_db), role: str = Depends(get_current_user_role)):
    return db.query(DBVehicle).all()




: Update vehicle (MANAGER ONLY)
@router.put("/{vehicle_id}", response_model=VehicleResponse)
def update_vehicle(vehicle_id: int, updated_vehicle: VehicleCreate, db: Session = Depends(get_db), role: str = Depends(get_current_user_role)):
    if role != "manager":
        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail="Access denied: Managers only")
    # ... keep your existing logic below this line ...
    db_vehicle = db.query(DBVehicle).filter(DBVehicle.id == vehicle_id).first()
    if not db_vehicle: raise HTTPException(status_code=404, detail="Vehicle not found")
    db_vehicle.make, db_vehicle.model, db_vehicle.year, db_vehicle.license_plate = updated_vehicle.make, updated_vehicle.model, updated_vehicle.year, updated_vehicle.license_plate
    db.commit()
    return db_vehicle

# 4. DELETE Route: Remove vehicle (MANAGER ONLY)
@router.delete("/{vehicle_id}")
def delete_vehicle(vehicle_id: int, db: Session = Depends(get_db), role: str = Depends(get_current_user_role)):
    if role != "manager":
        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail="Access denied: Managers only")
    # ... keep your existing logic below this line ...
    db_vehicle = db.query(DBVehicle).filter(DBVehicle.id == vehicle_id).first()
    if not db_vehicle: raise HTTPException(status_code=404, detail="Vehicle not found")
    db.delete(db_vehicle)
    db.commit()
    return {"message": "Deleted"}

# 5. Analytical Route: Fuel Efficiency (MANAGER ONLY)
@router.get("/{vehicle_id}/efficiency")
def get_vehicle_efficiency(vehicle_id: int, db: Session = Depends(get_db), role: str = Depends(get_current_user_role)):
    if role != "manager":
        raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail="Access denied: Managers only")
